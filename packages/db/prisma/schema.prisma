// Aerovy Travels — Phase 1 schema.
// See docs/architecture.md for the full ERD and monetary conventions.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth.js (NextAuth v5) tables + custom User columns
// ─────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  STAFF
  ADMIN
  SUPPLIER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(CUSTOMER)
  locale        String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  supplier      Supplier?
  bookings      Booking[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  auditLogs     AuditLog[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Supply side: suppliers own experiences and hotels.
// ─────────────────────────────────────────────────────────────

model Supplier {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String
  tradeLicenseNo String?
  payoutMethod   String?
  commissionRate Decimal  @default(0.15) @db.Decimal(5, 4)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences Experience[]
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

enum ExperienceStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model ExperienceCategory {
  id     String @id @default(cuid())
  slug   String @unique
  nameEn String
  nameAr String

  experiences Experience[]
}

model Experience {
  id              String           @id @default(cuid())
  slug            String           @unique
  supplierId      String?
  categoryId      String
  titleEn         String
  titleAr         String
  summaryEn       String
  summaryAr       String
  descriptionEn   String           @db.Text
  descriptionAr   String           @db.Text
  durationMinutes Int
  location        String
  ratingAvg       Decimal          @default(0) @db.Decimal(3, 2)
  ratingCount     Int              @default(0)
  featured        Boolean          @default(false)
  status          ExperienceStatus @default(PUBLISHED)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  category      ExperienceCategory @relation(fields: [categoryId], references: [id])
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  images        ExperienceImage[]
  variants      ExperienceVariant[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([categoryId, status])
  @@index([featured, status])
}

model ExperienceImage {
  id           String @id @default(cuid())
  experienceId String
  url          String
  altEn        String
  altAr        String
  order        Int    @default(0)

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@index([experienceId, order])
}

model ExperienceVariant {
  id           String  @id @default(cuid())
  experienceId String
  nameEn       String
  nameAr       String
  basePriceAED Decimal @db.Decimal(12, 2)
  maxPax       Int
  includes     Json?

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  schedules  Schedule[]

  @@index([experienceId])
}

model Schedule {
  id               String   @id @default(cuid())
  variantId        String
  startAt          DateTime
  capacity         Int
  booked           Int      @default(0)
  priceOverrideAED Decimal? @db.Decimal(12, 2)

  variant      ExperienceVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  bookingItems BookingItem[]

  @@index([variantId, startAt])
}

// ─────────────────────────────────────────────────────────────
// Commerce
// ─────────────────────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum BookingItemType {
  EXPERIENCE
  HOTEL
  TRANSFER
}

enum PaymentStatus {
  INITIATED
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PromoCodeKind {
  PERCENT
  FIXED
}

model Booking {
  id           String        @id @default(cuid())
  userId       String
  promoCodeId  String?
  subtotalAED  Decimal       @db.Decimal(12, 2)
  discountAED  Decimal       @default(0) @db.Decimal(12, 2)
  totalAED     Decimal       @db.Decimal(12, 2)
  currency     String        @default("AED")
  status       BookingStatus @default(PENDING)
  contactEmail String
  contactPhone String?
  notes        String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user      User         @relation(fields: [userId], references: [id])
  promoCode PromoCode?   @relation(fields: [promoCodeId], references: [id])
  items     BookingItem[]
  payment   Payment?

  @@index([userId, status])
  @@index([status, createdAt])
}

model BookingItem {
  id           String          @id @default(cuid())
  bookingId    String
  scheduleId   String?
  itemType     BookingItemType
  pax          Int
  unitPriceAED Decimal         @db.Decimal(12, 2)
  lineTotalAED Decimal         @db.Decimal(12, 2)
  scheduledFor DateTime?
  snapshot     Json?

  booking  Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  schedule Schedule? @relation(fields: [scheduleId], references: [id])

  @@index([bookingId])
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  provider    String
  providerRef String?
  status      PaymentStatus @default(INITIATED)
  amountAED   Decimal       @db.Decimal(12, 2)
  feeAED      Decimal       @default(0) @db.Decimal(12, 2)
  rawEvent    Json?
  capturedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
}

model PromoCode {
  id         String        @id @default(cuid())
  code       String        @unique
  kind       PromoCodeKind
  value      Decimal       @db.Decimal(12, 2)
  startsAt   DateTime
  endsAt     DateTime
  usageLimit Int?
  usageCount Int           @default(0)
  active     Boolean       @default(true)

  bookings Booking[]
}

// ─────────────────────────────────────────────────────────────
// Engagement
// ─────────────────────────────────────────────────────────────

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

model Review {
  id           String       @id @default(cuid())
  userId       String
  experienceId String
  rating       Int
  body         String       @db.Text
  status       ReviewStatus @default(PENDING)
  createdAt    DateTime     @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([userId, experienceId])
  @@index([experienceId, status])
}

model WishlistItem {
  id           String   @id @default(cuid())
  userId       String
  experienceId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([userId, experienceId])
}

// ─────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  entity    String
  entityId  String
  action    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId, createdAt])
}
