{
  "name": "@aerovy/api",
  "version": "0.0.0",
  "private": true,
  "description": "Aerovy Travels — tRPC routers and shared server contracts.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./root": {
      "types": "./src/router.ts",
      "import": "./src/router.ts"
    },
    "./trpc": {
      "types": "./src/trpc.ts",
      "import": "./src/trpc.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aerovy/config": "workspace:*",
    "@aerovy/db": "workspace:*",
    "@trpc/server": "^11.0.0",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
