# ──────────────────────────────────────────────────────────────
# Aerovy Travels — environment variables
# Copy this file to .env.local (git-ignored). Never commit secrets.
# Variables are grouped by phase; only fill in what the current phase needs.
# ──────────────────────────────────────────────────────────────

# Core (Phase 0+)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Database (Phase 1 Ticket 4)
# Neon or local Postgres (docker run -p 5432:5432 postgres:16)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aerovy?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/aerovy?schema=public"

# Auth.js (Phase 1 Ticket 7)
AUTH_SECRET=                              # openssl rand -base64 32
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=                          # shared with RESEND_API_KEY is fine

# Stripe (Phase 1 Ticket 10)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Media — Cloudflare R2 (Phase 1 Ticket 13). Swap to UploadThing if we pivot.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aerovy-media
R2_PUBLIC_URL=

# Email — Resend (Phase 1 Ticket 10)
RESEND_API_KEY=
EMAIL_FROM="Aerovy Travels <hello@aerovy.travel>"

# Cache / rate-limit — Upstash (Phase 1 Ticket 12)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Background jobs — Inngest (Phase 1 Ticket 9/12)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Search — pick one in Phase 1 Ticket 9 (leave the other blank)
# Meilisearch
MEILI_HOST=
MEILI_MASTER_KEY=
# Algolia
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# AI — Claude (Phase 2 Ticket 1)
ANTHROPIC_API_KEY=
AI_DAILY_SPEND_CAP_USD=5
AI_KILL_SWITCH=0                          # set to 1 to disable all AI calls

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
